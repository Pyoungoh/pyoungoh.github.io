---
import StoreBadge from './StoreBadge.astro';
import StoreBadgeGroup from './StoreBadgeGroup.astro';

const { title, description, links = [], lang = 'en', className = '' } = Astro.props;

const resolveKind = (href) => {
  if (href.includes('apps.apple.com')) return 'app-store';
  if (href.includes('play.google.com')) return 'google-play';
  return null;
};

const hasOnlyStoreLinks = links.length > 0 && links.every((link) => Boolean(resolveKind(link.href)));
---

<section class={`cta-panel ${className}`.trim()}>
  <h2>{title}</h2>
  <p>{description}</p>
  {hasOnlyStoreLinks ? (
    <StoreBadgeGroup links={links} lang={lang} />
  ) : (
    <ul class="cta-links">
      {links.map((link) => {
        const kind = resolveKind(link.href);

        return (
        <li>
          {kind ? <StoreBadge href={link.href} label={link.label} kind={kind} lang={lang} /> : <a href={link.href}>{link.label}</a>}
        </li>
        );
      })}
    </ul>
  )}
</section>
