---
import { headerLinks, siteTitle } from '../lib/site';

const { currentPath = '/', links = headerLinks, cta } = Astro.props;
---

<header class="site-header">
  <div class="shell">
    <a class="brand" href="/">{siteTitle}</a>
    <nav aria-label="Primary">
      <ul class="nav-list">
        {links.map((link) => {
          const active = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));

          return (
            <li>
              <a href={link.href} data-active={active ? 'true' : undefined}>
                {link.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
    {cta && (
      <a class="header-cta" href={cta.href}>
        {cta.label}
      </a>
    )}
  </div>
</header>
