---
type StoreKind = 'app-store' | 'google-play';
type Lang = 'ko' | 'en' | 'ja';

const { href, label, kind, lang = 'en' } = Astro.props as {
  href: string;
  label: string;
  kind: StoreKind;
  lang?: Lang;
};

const badgeAssets = {
  'app-store': {
    en: '/store-badges/app-store-en.svg',
    ko: '/store-badges/app-store-ko.svg',
    ja: '/store-badges/app-store-ja.svg',
  },
  'google-play': {
    en: '/store-badges/google-play-en.png',
    ko: '/store-badges/google-play-ko.png',
    ja: '/store-badges/google-play-ja.png',
  },
} as const;

const badgeAlt = {
  'app-store': {
    en: 'Download on the App Store',
    ko: 'App Store에서 다운로드',
    ja: 'App Storeからダウンロード',
  },
  'google-play': {
    en: 'Get it on Google Play',
    ko: 'Google Play에서 다운로드',
    ja: 'Google Play で手に入れよう',
  },
} as const;

const linkLabel = {
  'app-store': {
    en: 'Download Pace Lab on the App Store',
    ko: 'App Store에서 Pace Lab 다운로드',
    ja: 'App StoreでPace Labをダウンロード',
  },
  'google-play': {
    en: 'Get Pace Lab on Google Play',
    ko: 'Google Play에서 Pace Lab 다운로드',
    ja: 'Google PlayでPace Labを入手',
  },
} as const;

const localizedLang = lang in badgeAssets[kind] ? lang : 'en';
const imageSrc = badgeAssets[kind][localizedLang];
const imageAlt = badgeAlt[kind][localizedLang];
const ariaLabel = linkLabel[kind][localizedLang] ?? label;
---

<a class={`store-badge store-badge--${kind}`} href={href} aria-label={ariaLabel}>
  <img src={imageSrc} alt={imageAlt} loading="lazy" decoding="async" />
</a>
