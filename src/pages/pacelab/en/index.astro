---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import ScreenshotGallery from '../../../components/ScreenshotGallery.astro';
import heroScreenshot from '../../../assets/pacelab/en/home.png';
import paceCalculatorScreenshot from '../../../assets/pacelab/en/pace-calculator.png';
import racePaceScreenshot from '../../../assets/pacelab/en/race-pace.png';
import trainingPaceScreenshot from '../../../assets/pacelab/en/training-pace.png';
import racePredictorScreenshot from '../../../assets/pacelab/en/race-predictor.png';
import { paceLabStoreLinks } from '../../../lib/site';

const galleryItems = [
  {
    image: paceCalculatorScreenshot,
    alt: 'Pace Lab pace calculator screen',
    title: 'Pace calculator',
    description: 'Check pace and speed quickly from your distance and time.',
  },
  {
    image: racePaceScreenshot,
    alt: 'Pace Lab race pace calculator screen',
    title: 'Race pace calculator',
    description: 'Set a goal time and review race splits before race day.',
  },
  {
    image: trainingPaceScreenshot,
    alt: 'Pace Lab training pace calculator screen',
    title: 'Training pace calculator',
    description: 'See useful training paces from easy runs to marathon pace.',
  },
  {
    image: racePredictorScreenshot,
    alt: 'Pace Lab race time predictor screen',
    title: 'Race time predictor',
    description: 'Estimate a realistic finish time from a recent result.',
  },
];

const featureHighlights = [
  {
    href: '/pacelab/en/pace-calculator/',
    text: 'Calculate your perfect running pace for any distance',
  },
  {
    href: '/pacelab/en/race-pace-calculator/',
    text: 'Plan your race with accurate split times',
  },
  {
    href: '/pacelab/en/race-time-predictor/',
    text: 'Predict your finish time from past runs',
  },
  {
    href: '/pacelab/en/energy-gel-calculator/',
    text: 'Optimize your fueling strategy for long runs',
  },
  {
    href: '/pacelab/en/heart-rate-zone-calculator/',
    text: 'Train smarter with heart rate zones',
  },
];
---

<BaseLayout
  title="Running Pace Calculator & Marathon Tools | Pace Lab"
  description="Running pace calculator and marathon tools for 10K, half marathon, and marathon runners. Plan pace, splits, finish time, fueling, and heart rate zones in one app."
  lang="en"
  currentPath="/pacelab/en/"
>
  <section class="hero-panel hero-panel--showcase">
    <div class="hero-copy">
      <h1>Running Pace Calculator & Marathon Tools</h1>
      <p class="hero-lead">
        Know exactly how fast you need to run to hit your goal time. Plan your pace, splits, and race strategy — all in one app.
      </p>
      <div class="hero-body">
        <p>For runners training for 10K, half marathon, and marathon.</p>
        <p>No guessing. Just clear numbers for your next run.</p>
      </div>
    </div>

    <div class="hero-visual">
      <div class="device-frame device-frame--hero">
        <div class="device-frame__viewport">
          <Image
            src={heroScreenshot}
            alt="Pace Lab home screen"
            widths={[320, 420, 520, 640]}
            sizes="(max-width: 720px) 74vw, (max-width: 1080px) 34vw, 384px"
            loading="eager"
            format="webp"
            quality={90}
            class="device-frame__image--hero"
          />
        </div>
      </div>
    </div>
  </section>

  <section id="download" class="download-section">
    <div class="cta-panel cta-panel--wide-copy">
      <h2>Get the app and start planning your next run</h2>
      <p>Available on iOS & Android</p>
      <ul class="store-badge-group" data-lang="en">
        <li>
          <a
            class="store-badge store-badge--app-store"
            href={paceLabStoreLinks.en[0].href}
            aria-label="Download Pace Lab on the App Store"
          >
            <img
              src="/store-badges/app-store-en.svg"
              alt="Download on the App Store"
              loading="eager"
              decoding="async"
            />
          </a>
        </li>
        <li>
          <a
            class="store-badge store-badge--google-play"
            href={paceLabStoreLinks.en[1].href}
            aria-label="Get Pace Lab on Google Play"
          >
            <img
              src="/store-badges/google-play-en.png"
              alt="Get it on Google Play"
              loading="eager"
              decoding="async"
            />
          </a>
        </li>
      </ul>
    </div>
  </section>

  <ScreenshotGallery
    title="App preview"
    description="See the core calculators runners use to plan pace, split times, and race-day decisions in seconds."
    items={galleryItems}
    className="screenshot-gallery--wide-copy"
  />

  <section class="plain-panel feature-benefits-panel">
    <div class="section-heading">
      <h2>Why runners use Pace Lab</h2>
      <p>Simple tools for race planning, training decisions, and faster answers before every run.</p>
    </div>

    <ul class="feature-benefit-list">
      {featureHighlights.map((feature) => (
        <li>
          <a href={feature.href}>{feature.text}</a>
        </li>
      ))}
    </ul>

    <p class="internal-links">
      Popular tools:
      {' '}
      <a href="/pacelab/en/pace-calculator/">Pace calculator</a>,
      {' '}
      <a href="/pacelab/en/race-time-predictor/">Race predictor</a>,
      {' '}
      <a href="/pacelab/en/race-pace-calculator/">Split chart</a>
    </p>
  </section>

  <section class="plain-panel trust-panel">
    <h2>Built to stay simple</h2>
    <p>No login required. No personal data stored. Built for runners.</p>
  </section>

  <section class="plain-panel seo-panel">
    <h2>What is a running pace calculator?</h2>
    <p>
      A running pace calculator shows exactly how fast you should run to hit your goal time — for 5K, half marathon, and marathon.
    </p>
    <ul class="seo-list">
      <li>Calculate your pace for any distance</li>
      <li>Plan accurate split times</li>
      <li>Predict your finish time from past runs</li>
      <li>Train smarter with heart rate zones</li>
    </ul>
    <p>Pace Lab combines all these tools in one simple app, so you can plan better and run with confidence.</p>
  </section>

  <section class="plain-panel support-panel">
    <h2>Support</h2>
    <p>
      <a href="mailto:slowlane.dev@gmail.com">slowlane.dev@gmail.com</a>
    </p>

    <h2>Privacy Policy</h2>
    <p>
      <a href="https://pyoungoh.github.io/pacelab/en/privacy/">View Privacy Policy</a>
    </p>
  </section>
</BaseLayout>

<style>
  :global(.download-section .cta-panel) {
    text-align: center;
  }

  :global(.download-section .cta-panel p) {
    max-width: none;
    margin-bottom: 0.9rem;
    color: var(--muted);
    font-size: 0.95rem;
  }

  :global(.download-section .store-badge-group) {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 28px;
    list-style: none;
    width: fit-content;
    max-width: 100%;
    padding: 0;
    margin: 1.15rem auto 0;
    flex-wrap: wrap;
  }

  :global(.download-section .store-badge-group > li) {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  :global(.download-section .store-badge) {
    min-height: 56px;
    align-items: center;
    justify-content: center;
  }

  .feature-benefit-list {
    list-style: none;
    padding: 0;
    margin: 1.25rem 0 0;
    display: grid;
    gap: 0.85rem;
  }

  .feature-benefit-list li {
    margin: 0;
  }

  .feature-benefit-list a {
    display: block;
    padding: 0.95rem 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: rgba(248, 250, 255, 0.82);
    text-decoration: none;
    font-weight: 600;
  }

  .feature-benefit-list a:hover {
    border-color: rgba(77, 94, 168, 0.28);
    background: rgba(241, 246, 255, 0.96);
  }

  .internal-links {
    margin-top: 1rem;
    color: var(--muted);
  }

  .trust-panel p {
    max-width: 72ch;
  }

  .seo-panel h2 {
    text-wrap: wrap;
  }

  .seo-panel p,
  .seo-list {
    max-width: none;
  }

  .seo-list {
    margin: 1rem 0;
    padding-left: 1.2rem;
  }

  .seo-list li + li {
    margin-top: 0.5rem;
  }

  @media (max-width: 720px) {
    :global(.download-section .store-badge-group) {
      gap: 20px;
    }

    :global(.download-section .store-badge) {
      min-height: 52px;
    }

    :global(.download-section .store-badge img) {
      height: 52px;
    }
  }
</style>
