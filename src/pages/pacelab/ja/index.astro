---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CTA from '../../../components/CTA.astro';
import PaceLabHero from '../../../components/PaceLabHero.astro';
import ScreenshotGallery from '../../../components/ScreenshotGallery.astro';
import heroScreenshot from '../../../assets/pacelab/ja/home.png';
import paceCalculatorScreenshot from '../../../assets/pacelab/ja/pace-calculator.png';
import racePaceScreenshot from '../../../assets/pacelab/ja/race-pace.png';
import trainingPaceScreenshot from '../../../assets/pacelab/ja/training-pace.png';
import racePredictorScreenshot from '../../../assets/pacelab/ja/race-predictor.png';
import { paceLabStoreLinks } from '../../../lib/site';

const galleryItems = [
  {
    image: paceCalculatorScreenshot,
    alt: 'Pace Lab ペース計算機画面',
    title: 'ペース計算機',
    description: '距離と時間からペースと速度をすばやく確認できます。',
  },
  {
    image: racePaceScreenshot,
    alt: 'Pace Lab レースペース計算画面',
    title: 'レースペース計算',
    description: '目標タイムをもとにレースペースとスプリットを事前に確認できます。',
  },
  {
    image: trainingPaceScreenshot,
    alt: 'Pace Lab トレーニングペース計算画面',
    title: 'トレーニングペース計算',
    description: 'イージーランからマラソンペースまで練習ペースを整理できます。',
  },
  {
    image: racePredictorScreenshot,
    alt: 'Pace Lab レース予想タイム画面',
    title: 'レース予想タイム',
    description: '最近の記録から現実的な予想タイムを確認できます。',
  },
];

const featureHighlights = [
  {
    href: '/pacelab/ja/pace-calculator/',
    text: 'どんな距離でも最適なランニングペースを計算できます',
  },
  {
    href: '/pacelab/ja/race-pace-calculator/',
    text: '正確なスプリットでレースプランを立てられます',
  },
  {
    href: '/pacelab/ja/race-time-predictor/',
    text: '過去の記録からゴールタイムを予測できます',
  },
  {
    href: '/pacelab/ja/energy-gel-calculator/',
    text: 'ロングラン向けの補給戦略を最適化できます',
  },
  {
    href: '/pacelab/ja/heart-rate-zone-calculator/',
    text: '心拍ゾーンでより賢くトレーニングできます',
  },
];
---

<BaseLayout
  title="ランニングペース計算機 & マラソンツール | Pace Lab"
  description="10K、ハーフマラソン、マラソンのランナー向けランニングペース計算機とマラソンツール。ペース、スプリット、ゴールタイム予測、補給計画、心拍ゾーンを1つのアプリで確認できます。"
  lang="ja"
  currentPath="/pacelab/ja/"
>
  <PaceLabHero
    title="ランニングペース計算機 & マラソンツール"
    lead="目標タイムに届くために、どのくらいの速さで走ればいいかを正確に把握できます。ペース、スプリット、レース戦略をひとつのアプリで計画できます。"
    paragraphs={[
      '10K、ハーフマラソン、マラソンを目指すランナー向けのアプリです。',
      '勘に頼らず、次のランに必要な数字をはっきり確認できます。',
    ]}
    image={heroScreenshot}
    imageAlt="Pace Lab 日本語ホーム画面"
    frameClass="device-frame--hero"
    imageClass="device-frame__image--hero"
  />

  <section id="download" class="download-section">
    <CTA title="アプリをダウンロードして次のランを計画しよう" description="iOSとAndroidで利用できます" links={paceLabStoreLinks.ja} lang="ja" className="cta-panel--wide-copy" />
  </section>

  <ScreenshotGallery
    title="アプリ画面"
    description="ランナーがよく使う計算機を中心に、ペースやスプリット、レース戦略をすばやく確認できます。"
    items={galleryItems}
    className="screenshot-gallery--wide-copy"
  />

  <section class="plain-panel feature-benefits-panel">
    <div class="section-heading">
      <h2>ランナーがPace Labを使う理由</h2>
      <p>トレーニング判断、レース戦略、記録予測に必要な計算をシンプルにすばやく確認できます。</p>
    </div>

    <ul class="feature-benefit-list">
      {featureHighlights.map((feature) => (
        <li>
          <a href={feature.href}>{feature.text}</a>
        </li>
      ))}
    </ul>

    <p class="internal-links">
      人気ツール:
      {' '}
      <a href="/pacelab/ja/pace-calculator/">ペース計算機</a>,
      {' '}
      <a href="/pacelab/ja/race-time-predictor/">レース予想</a>,
      {' '}
      <a href="/pacelab/ja/race-pace-calculator/">スプリット表</a>
    </p>
  </section>

  <section class="plain-panel trust-panel">
    <h2>シンプルに使える設計</h2>
    <p>ログイン不要。個人データは保存しません。ランナーのために作りました。</p>
  </section>

  <section class="plain-panel seo-panel">
    <h2>ランニングペース計算機とは？</h2>
    <p>
      ランニングペース計算機は、目標タイムに合わせてどのくらいの速さで走ればよいかを正確に示してくれるツールです。5K、ハーフマラソン、マラソンの準備に役立ちます。
    </p>
    <ul class="seo-list">
      <li>どんな距離でもペースを計算</li>
      <li>正確なスプリットを計画</li>
      <li>過去の記録からゴールタイムを予測</li>
      <li>心拍ゾーンでより賢くトレーニング</li>
    </ul>
    <p>Pace Labはこれらのツールをひとつのシンプルなアプリにまとめ、より自信を持って計画し、走れるようにサポートします。</p>
  </section>

  <section class="plain-panel support-panel">
    <h2>サポート</h2>
    <p>
      <a href="mailto:slowlane.dev@gmail.com">slowlane.dev@gmail.com</a>
    </p>

    <h2>プライバシーポリシー</h2>
    <p>
      <a href="https://pyoungoh.github.io/pacelab/ja/privacy/">プライバシーポリシーを見る</a>
    </p>
  </section>
</BaseLayout>

<style>
  :global(.download-section .cta-panel) {
    text-align: center;
  }

  :global(.download-section .cta-panel p) {
    max-width: none;
    margin-bottom: 0.9rem;
    color: var(--muted);
    font-size: 0.95rem;
  }

  :global(.download-section .store-badge-group) {
    justify-content: center;
    align-items: center;
    gap: 28px;
  }

  :global(.download-section .store-badge-group > li) {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  :global(.download-section .store-badge) {
    min-height: 56px;
    align-items: center;
    justify-content: center;
  }

  :global(.download-section .store-badge img) {
    height: 56px;
    width: auto;
    max-width: 100%;
  }

  .feature-benefit-list {
    list-style: none;
    padding: 0;
    margin: 1.25rem 0 0;
    display: grid;
    gap: 0.85rem;
  }

  .feature-benefit-list li {
    margin: 0;
  }

  .feature-benefit-list a {
    display: block;
    padding: 0.95rem 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: rgba(248, 250, 255, 0.82);
    text-decoration: none;
    font-weight: 600;
  }

  .feature-benefit-list a:hover {
    border-color: rgba(77, 94, 168, 0.28);
    background: rgba(241, 246, 255, 0.96);
  }

  .internal-links {
    margin-top: 1rem;
    color: var(--muted);
  }

  .trust-panel p {
    max-width: 72ch;
  }

  .seo-panel h2 {
    text-wrap: wrap;
  }

  .seo-panel p,
  .seo-list {
    max-width: none;
  }

  .seo-list {
    margin: 1rem 0;
    padding-left: 1.2rem;
  }

  .seo-list li + li {
    margin-top: 0.5rem;
  }

  @media (max-width: 720px) {
    :global(.download-section .store-badge-group) {
      gap: 20px;
    }

    :global(.download-section .store-badge) {
      min-height: 52px;
    }

    :global(.download-section .store-badge img) {
      height: 52px;
    }
  }
</style>
